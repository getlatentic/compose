{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",

    /* Resolve the in-repo `ai-editor` workspace package to its TS source for
       typechecking (mirrors the Vite alias). External consumers resolve the
       built `dist/` via the package's own `exports`. */
    "baseUrl": ".",
    "paths": {
      "ai-editor": ["./packages/rich-editor/src/index.ts"]
    },

    /* Linting */
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true
  },
  "include": ["src", "packages/*/src"]
}
