{
  "name": "compose",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "license": "MIT",
  "scripts": {
    "dev": "concurrently --names bob-api,vite --prefix-colors blue,green --kill-others-on-fail 'pnpm dev:bob-api' 'pnpm dev:vite'",
    "dev:vite": "vite",
    "dev:bob-api": "cargo run --quiet --bin bob-api",
    "build": "pnpm build:wasm && pnpm typecheck && vite build",
    "build:wasm": "wasm-pack build crates/workspace-index-wasm --target web --out-dir ../../src/wasm/workspace_index_pkg --no-pack && rm -f src/wasm/workspace_index_pkg/.gitignore",
    "preview": "vite preview",
    "tauri": "tauri",
    "setup:dev-signing": "bash scripts/setup-dev-signing.sh",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.node.json",
    "test": "vitest run",
    "bench:baseline": "vitest run --config vitest.bench.config.ts",
    "test:rust": "cargo test",
    "check": "pnpm build && pnpm test && pnpm test:rust"
  },
  "dependencies": {
    "@carbon/react": "^1.108.0",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-opener": "^2",
    "@tiptap/extension-bubble-menu": "^3.23.6",
    "@tiptap/extension-image": "^3.23.6",
    "@tiptap/extension-link": "^3.23.6",
    "@tiptap/extension-table": "^3.23.6",
    "@tiptap/extension-table-cell": "^3.23.6",
    "@tiptap/extension-table-header": "^3.23.6",
    "@tiptap/extension-table-row": "^3.23.6",
    "@tiptap/extension-task-item": "^3.23.6",
    "@tiptap/extension-task-list": "^3.23.6",
    "@tiptap/markdown": "^3.23.6",
    "@tiptap/pm": "^3.23.6",
    "@tiptap/react": "^3.23.6",
    "@tiptap/starter-kit": "^3.23.6",
    "comlink": "^4.4.2",
    "decode-named-character-reference": "1.3.0",
    "hast-util-to-jsx-runtime": "^2.3.6",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-is": "18.3.1",
    "rehype-sanitize": "^6.0.0",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "unified": "^11.0.5",
    "yaml": "^2.9.0",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/language": "^6.12.3",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.43.0",
    "@tailwindcss/typography": "^0.5.16",
    "@tauri-apps/cli": "^2",
    "@types/hast": "^3.0.4",
    "@types/node": "^24.10.1",
    "@types/react": "^18.3.23",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^4.6.0",
    "autoprefixer": "^10.4.21",
    "codemirror": "^6.0.2",
    "concurrently": "^10.0.0",
    "postcss": "^8.5.6",
    "sass": "^1.100.0",
    "tailwindcss": "^3.4.17",
    "typescript": "~5.8.3",
    "vite": "^7.0.4",
    "vitest": "^3.2.4"
  }
}
