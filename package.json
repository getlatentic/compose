{
  "name": "compose",
  "private": true,
  "version": "0.0.1-alpha.12",
  "type": "module",
  "license": "MIT",
  "scripts": {
    "dev": "vite",
    "build": "pnpm build:wasm && pnpm typecheck && vite build",
    "build:wasm": "wasm-pack build crates/workspace-index-wasm --target web --out-dir ../../src/wasm/workspace_index_pkg --no-pack && rm -f src/wasm/workspace_index_pkg/.gitignore",
    "build:editor": "pnpm --filter ai-editor build",
    "preview": "vite preview",
    "tauri": "tauri",
    "clean": "rm -rf target dist",
    "setup:dev-signing": "bash scripts/setup-dev-signing.sh",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.node.json",
    "test": "vitest run",
    "bench:baseline": "vitest run --config vitest.bench.config.ts",
    "test:rust": "cargo test",
    "test:coverage": "vitest run --coverage --coverage.provider=v8 --coverage.include='src/**' --coverage.include='packages/*/src/**' --coverage.exclude='**/*.test.{ts,tsx}' --coverage.exclude='**/*.d.ts' --coverage.reporter=text-summary",
    "coverage:rust": "cd src-tauri && cargo llvm-cov --workspace --summary-only",
    "check": "pnpm build:editor && pnpm build && pnpm test && pnpm test:rust",
    "test:browser": "vitest run --config vitest.browser.config.ts"
  },
  "dependencies": {
    "@carbon/react": "^1.108.0",
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/language": "^6.12.3",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.43.0",
    "@tanstack/react-virtual": "^3.14.3",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-opener": "^2",
    "@tauri-apps/plugin-process": "^2",
    "@tauri-apps/plugin-updater": "^2",
    "ai-editor": "workspace:*",
    "comlink": "^4.4.2",
    "decode-named-character-reference": "1.3.0",
    "dompurify": "^3.4.11",
    "hast-util-to-html": "^9.0.5",
    "hast-util-to-jsx-runtime": "^2.3.6",
    "katex": "^0.17.0",
    "lucide-react": "^1.17.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-is": "18.3.1",
    "rehype-sanitize": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "unified": "^11.0.5",
    "yaml": "^2.9.0",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.16",
    "@tauri-apps/cli": "^2",
    "@types/dompurify": "^3.2.0",
    "@types/hast": "^3.0.4",
    "@types/katex": "^0.16.8",
    "@types/node": "^24.10.1",
    "@types/react": "^18.3.23",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^4.6.0",
    "@vitest/browser": "3.2.6",
    "@vitest/coverage-v8": "3.2.6",
    "autoprefixer": "^10.4.21",
    "codemirror": "^6.0.2",
    "concurrently": "^10.0.0",
    "jsdom": "^29.1.1",
    "playwright": "^1.61.1",
    "postcss": "^8.5.6",
    "react-scan": "^0.5.7",
    "sass": "^1.100.0",
    "tailwindcss": "^3.4.17",
    "typescript": "~5.8.3",
    "vite": "^7.3.6",
    "vitest": "^3.2.6"
  },
  "pnpm": {
    "overrides": {
      "jiti": "1.21.7"
    },
    "peerDependencyRules": {
      "allowedVersions": {
        "@amiceli/vitest-cucumber>vitest": "3"
      }
    }
  }
}
