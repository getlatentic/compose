{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Compose",
  "version": "0.0.1-alpha.12",
  "identifier": "ai.latentic.compose",
  "build": {
    "beforeDevCommand": "pnpm dev:vite",
    "devUrl": "http://localhost:1421",
    "beforeBuildCommand": "bash src-tauri/scripts/fetch-runtime.sh && pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Compose",
        "width": 1440,
        "height": 920,
        "minWidth": 1120,
        "minHeight": 760,
        "backgroundColor": "#ffffff",
        "backgroundThrottling": "disabled",
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "trafficLightPosition": { "x": 8, "y": 21 },
        "decorations": true,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": []
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEIxRUE4NjE4QkU0MTIwRTEKUldUaElFRytHSWJxc1d0MHFLa0lKNi9oVUE5d0ozNFlsdFZycWljOVpqUk43Y2NUZ1krcUQ0T3UK",
      "endpoints": [
        "https://github.com/getlatentic/compose/releases/latest/download/latest.json"
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": {
      "binaries/runtime/": "runtime"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "fileAssociations": [
      {
        "name": "Markdown",
        "description": "Markdown document",
        "ext": ["md", "markdown", "mdown", "mkd"],
        "mimeType": "text/markdown",
        "role": "Editor",
        "rank": "Alternate"
      }
    ]
  }
}
