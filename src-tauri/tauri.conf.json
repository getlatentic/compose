{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Compose",
  "version": "0.0.1-alpha.1",
  "identifier": "com.compose.app",
  "build": {
    "beforeDevCommand": "pnpm dev:vite",
    "devUrl": "http://localhost:1421",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Compose",
        "width": 1440,
        "height": 920,
        "minWidth": 1120,
        "minHeight": 760,
        "backgroundColor": "#ffffff",
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "trafficLightsPosition": { "x": 18, "y": 8 }
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' asset: http://asset.localhost; style-src 'self' 'unsafe-inline'; script-src 'self'; connect-src ipc: http://ipc.localhost http://localhost:1421 ws://localhost:1421 ws://localhost:1423",
      "assetProtocol": {
        "enable": true,
        "scope": []
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
