{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Compose",
  "version": "0.0.1-alpha.1",
  "identifier": "com.compose.app",
  "build": {
    "beforeDevCommand": "pnpm dev:vite",
    "devUrl": "http://localhost:1421",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Compose",
        "width": 1440,
        "height": 920,
        "minWidth": 1120,
        "minHeight": 760,
        "backgroundColor": "#ffffff",
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "trafficLightPosition": { "x": 8, "y": 21 },
        "decorations": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": []
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "fileAssociations": [
      {
        "name": "Markdown",
        "description": "Markdown document",
        "ext": ["md", "markdown", "mdown", "mkd"],
        "mimeType": "text/markdown",
        "role": "Editor",
        "rank": "Alternate"
      }
    ]
  }
}
