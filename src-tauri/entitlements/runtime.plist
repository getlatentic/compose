<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  Hardened-runtime exceptions for the bundled Node binary (Resources/runtime/node).
  Tauri signs the app, frameworks and sidecars but not Resources, so fetch-runtime.sh
  signs node with these. They are the standard set an embedded V8/Node runtime needs:
    allow-jit / allow-unsigned-executable-memory  — V8's JIT writes+executes memory.
    disable-library-validation                    — load native addons (.node) that
                                                     npm installs at runtime, signed by
                                                     others or unsigned.
    allow-dyld-environment-variables              — honour NODE_OPTIONS and the DYLD_*
                                                     some native modules rely on.
  uv/uvx are plain native binaries and get hardened runtime with no exceptions.
-->
<plist version="1.0">
<dict>
	<key>com.apple.security.cs.allow-jit</key>
	<true/>
	<key>com.apple.security.cs.allow-unsigned-executable-memory</key>
	<true/>
	<key>com.apple.security.cs.disable-library-validation</key>
	<true/>
	<key>com.apple.security.cs.allow-dyld-environment-variables</key>
	<true/>
</dict>
</plist>
